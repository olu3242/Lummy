{
  "extends": "./.eslintrc.base.cjs",
  "overrides": [
    {
      "files": [
        "src/**/*.{ts,tsx}",
        "middleware.ts"
      ],
      "extends": [
        "./.eslintrc.next.cjs"
      ]
    },
    {
      "files": [
        "apps/**/*.{ts,tsx}"
      ],
      "excludedFiles": [
        "apps/**/src/**/*.{tsx,jsx}"
      ],
      "extends": [
        "./.eslintrc.node.cjs"
      ]
    },
    {
      "files": [
        "packages/**/*.ts"
      ],
      "extends": [
        "./.eslintrc.library.cjs"
      ]
    },
    {
      "files": [
        "src/app/**/*.{ts,tsx}",
        "src/pages/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@lummy/db-core",
              "../../packages/db-core/*",
              "packages/db-core/*"
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/events/src/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@lummy/analytics-engine",
              "@lummy/ai-engine"
            ]
          }
        ]
      }
    },
    {
      "files": [
        "apps/workers/src/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@lummy/db-core",
              "@lummy/repositories"
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/repositories/src/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "src/*",
              "src/**",
              "@/components/*",
              "@/app/*",
              "../../*/src",
              "../*/src"
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/telemetry/src/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@lummy/ai-engine",
              "@lummy/automation-engine",
              "@lummy/recommendation-engine"
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/**/*.ts",
        "apps/**/*.ts",
        "apps/**/*.tsx"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@lummy/*/src",
              "@lummy/*/src/*",
              "../../*/src/*",
              "../*/src/*"
            ]
          }
        ]
      }
    }
  ]
}
