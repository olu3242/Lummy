# Supabase Edge Function secrets for whatsapp-webhook
# Set via: supabase secrets set KEY=value
# Or: supabase secrets set --env-file supabase/functions/whatsapp-webhook/.env

# Required: Supabase service role (injected automatically by Supabase runtime)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required: Meta webhook verify token
# Must match the value set in Meta App Dashboard → WhatsApp → Configuration → Webhook
META_VERIFY_TOKEN=your-arbitrary-secret-token

# Optional but strongly recommended: Meta App Secret for HMAC signature verification
# Meta App Dashboard → App Settings → Basic → App Secret
META_APP_SECRET=your-meta-app-secret
