# ============================================================
# LUMMY — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # server-only — never expose to client

# ── AI ───────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# platform.openai.com → API Keys  (optional — only needed if OpenAI features are enabled)
OPENAI_API_KEY=sk-proj-your-openai-key

# ── Payments ─────────────────────────────────────────────────
# Paystack (primary — required for NGN checkout)
# dashboard.paystack.com → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public  # same as above, for client-side SDK

# Stripe (secondary — international)
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret   # Stripe Dashboard → Webhooks → Signing secret

# Flutterwave (optional — West Africa alternative)
# dashboard.flutterwave.com → Settings → API Keys
FLUTTERWAVE_SECRET_KEY=FLWSECK_your-flutterwave-secret
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your-flutterwave-public

# ── WhatsApp / Meta Cloud API ─────────────────────────────────
# Meta App Dashboard → WhatsApp → API Setup
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id            # e.g. 1094766503726081

# Meta webhook verify token — set the SAME arbitrary string in:
#   1. This file (used by Next.js webhook route)
#   2. Meta App Dashboard → WhatsApp → Configuration → Webhook → Verify Token
# Callback URL to register: https://your-domain.com/api/webhooks/whatsapp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-arbitrary-secret-token

# Meta App Dashboard → App Settings → Basic → App Secret
# Used for HMAC-SHA256 webhook payload verification
META_APP_SECRET=your-meta-app-secret

# Supabase Edge Function secrets — set separately (not in .env.local):
#   supabase secrets set META_VERIFY_TOKEN=<same as WHATSAPP_WEBHOOK_VERIFY_TOKEN>
#   supabase secrets set META_APP_SECRET=<same as META_APP_SECRET>
#   supabase secrets set SUPABASE_URL=<same as NEXT_PUBLIC_SUPABASE_URL>
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<same as SUPABASE_SERVICE_ROLE_KEY>

# ── Email ────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key

# ── Cron Jobs ────────────────────────────────────────────────
# Arbitrary secret that authorizes POST /api/jobs/run and /api/cron/*
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://lummy.co                     # no trailing slash; use http://localhost:3000 locally
NEXT_PUBLIC_APP_ENV=development                          # development | staging | production
NEXT_PUBLIC_APP_VERSION=1.0.0                            # shown in /api/health response

# ── Storage ──────────────────────────────────────────────────
NEXT_PUBLIC_STORAGE_URL=https://your-project.supabase.co/storage/v1/s3

# ── Feature Flags ────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# ── Monitoring (optional) ────────────────────────────────────
# SENTRY_DSN=your-sentry-dsn
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
