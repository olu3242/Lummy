# ============================================================
# LUMMY — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Payments ----
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public
FLUTTERWAVE_SECRET_KEY=FLWSECK_your-flutterwave-secret
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your-flutterwave-public

# ---- AI ----
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ---- WhatsApp / Meta Cloud API ----
# Meta App Dashboard → WhatsApp → API Setup
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Meta App Dashboard → WhatsApp → Configuration → Webhook
# Set Callback URL: https://lummy.co/api/webhooks/whatsapp
# Set Verify Token: same value as WHATSAPP_WEBHOOK_VERIFY_TOKEN below
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-arbitrary-secret-token

# Meta App Dashboard → App Settings → Basic → App Secret
# Used for HMAC-SHA256 webhook payload verification
META_APP_SECRET=your-meta-app-secret

# Supabase Edge Function secrets (set separately via CLI):
#   supabase secrets set META_VERIFY_TOKEN=your-arbitrary-secret-token
#   supabase secrets set META_APP_SECRET=your-meta-app-secret
#   supabase secrets set SUPABASE_URL=https://your-project.supabase.co
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App Config ----
NEXT_PUBLIC_APP_URL=https://lummy.co
NEXT_PUBLIC_APP_ENV=development

# ---- Storage ----
NEXT_PUBLIC_STORAGE_URL=https://your-project.supabase.co/storage/v1

# ---- Monitoring (optional) ----
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
