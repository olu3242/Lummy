{
  "name": "lummy-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "turbo run build",
    "start": "next start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:deps": "madge --circular --extensions ts packages apps",
    "check:imports": "eslint . --max-warnings=0",
    "validate:migrations": "test -d supabase/migrations && find supabase/migrations -name \"*.sql\" | wc -l",
    "ci:validate": "pnpm run typecheck && pnpm run lint && pnpm run check:deps && pnpm run validate:migrations",
    "check:graph": "madge --circular --extensions ts packages apps src"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.383.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "@supabase/supabase-js": "^2.57.4",
    "@supabase/ssr": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "turbo": "^2.0.0",
    "madge": "^8.0.0",
    "eslint-plugin-boundaries": "^4.2.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@10.28.1"
}
